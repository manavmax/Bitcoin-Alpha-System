\section{Experimental Setup}

\subsection{Data}
Daily BTC OHLCV data from 2018--2025.

\subsection{Metrics}
Directional Accuracy:
\begin{equation}
DA = \frac{\text{Correct Trades}}{\text{Executed Trades}}
\end{equation}

Coverage:
\begin{equation}
Coverage = \frac{\text{Trade Days}}{\text{Total Days}}
\end{equation}

